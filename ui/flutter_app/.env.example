# BovaPlayer 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# 应用环境 (development, test, production)
ENVIRONMENT=development

# Supabase 配置
# 从 https://supabase.com/dashboard 获取
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# 是否启用 Supabase 调试日志
SUPABASE_DEBUG=false

# API 配置
API_BASE_URL=https://api.bovaplayer.com

# 功能开关
ENABLE_LOGGING=true
ENABLE_ANALYTICS=false

# GitHub OAuth 配置
# 从 https://github.com/settings/developers 获取
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_REDIRECT_URI=bovaplayer://auth/github/callback

# 支付配置（可选）
# ALIPAY_APP_ID=
# WECHAT_APP_ID=
# STRIPE_PUBLISHABLE_KEY=
